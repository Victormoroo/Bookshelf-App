# Supabase — copy this file to `.env.local` and fill in your project's values.
# These are EXPO_PUBLIC_* (embedded in the client bundle); use the publishable
# (anon) key here, never a service-role/secret key.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-publishable-key
